{
  "name": "@scripts/gm-polyfill",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "GM.ts",
    "GM_addStyle.ts",
    "GM_getResourceText.ts",
    "GM_getValue.ts",
    "GM_setClipboard.ts",
    "GM_setValue.ts",
    "GM_xmlhttpRequest.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "concurrently -m 1 --timings npm:lint:*",
    "lint:type-check": "tsc -p tsconfig.json --noEmit",
    "lint:formatter": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "fix:formatter": "oxfmt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.2"
  },
  "license": "MIT"
}
