{
  "name": "@scripts/flow",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "concurrently -m 1 --timings npm:lint:*",
    "lint:type-check": "tsc -p tsconfig.json --noEmit",
    "lint:formatter": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "fix:formatter": "oxfmt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.58.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3"
  },
  "license": "MIT"
}
