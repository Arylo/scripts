{
  "name": "@arylo/esbuild-plugin-css-minify-text",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "concurrently npm:lint:*",
    "lint:type-check": "tsc -p tsconfig.json --noEmit",
    "lint:formatter": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "fix:formatter": "oxfmt"
  },
  "peerDependencies": {
    "esbuild": "^0.21.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.24.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
