{
  "name": "@scripts/readme-build",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "bin": {
    "readme-build": "./bin/readme-build"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "concurrently -m 1 --timings npm:lint:*",
    "lint:type-check": "tsc -p tsconfig.json --noEmit",
    "lint:formatter": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "fix:formatter": "oxfmt"
  },
  "dependencies": {
    "@scripts/build-fs": "1.0.0",
    "@scripts/build-utils": "1.0.0",
    "@scripts/md-generator": "1.0.0",
    "glob": "^10.3.10",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "concurrently": "^8.2.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5"
  }
}
