    "lodash": "^4.17.23",
    "md5": "^2.3.0",
    "md5-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/download": "^8.0.5",
    "@types/lodash": "^4.17.24",
    "@types/md5": "^2.3.6",
    "concurrently": "^8.2.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.58.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3"
  }
