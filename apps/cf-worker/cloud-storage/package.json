{
  "name": "@scripts/cloud-storage",
  "private": true,
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "vite --host",
    "preview": "npm run build && vite preview",
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.json",
    "lint": "concurrently -m 1 --timings npm:lint:*",
    "lint:type-check": "tsc -p tsconfig.json --noEmit",
    "lint:formatter": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "fix": "concurrently -m 1 --timings npm:fix:*",
    "fix:formatter": "oxfmt"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.1",
    "@videojs/react": "^10.0.0-beta.14",
    "classcat": "^5.0.5",
    "crypto-js": "^4.2.0",
    "hono": "4.11.1",
    "mime-types": "^2.1.35",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-router": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.15.3",
    "@eslint/js": "9.39.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "globals": "16.5.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.58.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "vite": "^6.0.0",
    "wrangler": "^4.80.0"
  },
  "cloudflare": {
    "label": "Vite React Template",
    "products": [
      "Workers"
    ],
    "categories": [],
    "publish": true
  }
}
